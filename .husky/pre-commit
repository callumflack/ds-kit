#!/bin/sh
set -e

pnpm test

STAGED_FILES=$(mktemp)
trap 'rm -f "$STAGED_FILES"' EXIT HUP INT TERM

git diff --cached --name-only --diff-filter=ACMR -z >"$STAGED_FILES"
if [ ! -s "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

xargs -0 pnpm dlx ultracite fix <"$STAGED_FILES"
xargs -0 git add -- <"$STAGED_FILES"

echo "✨ Files formatted by Ultracite"
