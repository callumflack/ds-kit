{
  "name": "ds-kit",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "lucide-react": "^0.511.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "ultracite": "7.4.3",
    "vitest": "^4.1.3"
  },
  "scripts": {
    "add:ds-kit": "npx shadcn@latest add @ds-kit/core && npm run post-add:ds-kit && npm run verify:ds-kit",
    "docs:build": "pnpm --dir docs build",
    "docs:dev": "pnpm --dir docs dev",
    "docs:lint": "pnpm --dir docs lint",
    "post-add:ds-kit": "node scripts/post-add-ds-kit.mjs && node scripts/verify-tw-merge-theme.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:registry-surface": "node scripts/verify-registry-surface.mjs",
    "verify:ds-kit": "node scripts/verify-ds-kit-install.mjs",
    "verify:tw-merge": "node scripts/verify-tw-merge-theme.mjs",
    "verify:ultracite": "node scripts/verify-ultracite.mjs",
    "registry:build": "npx shadcn@latest build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  }
}
